.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header-section {
  padding: 20rpx;
}

.points-card {
  background: linear-gradient(135deg, #ff6347 0%, #ff7f50 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.points-balance {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.balance-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 8rpx;
}

.balance-value {
  font-size: 72rpx;
  font-weight: bold;
  color: #ffffff;
  line-height: 1;
}

.points-detail {
  display: flex;
  justify-content: space-around;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.3);
}

.detail-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 4rpx;
}

.detail-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
}

.detail-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: rgba(255, 255, 255, 0.3);
}

.level-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.level-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.level-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.level-tip {
  font-size: 22rpx;
  color: #ff6347;
}

.level-progress {
  width: 100%;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background-color: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #ff6347, #ff7f50);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.action-row {
  display: flex;
  gap: 20rpx;
}

.redeem-btn,
.coupon-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  text-align: center;
}

.redeem-btn {
  background: linear-gradient(135deg, #ff6347 0%, #ff7f50 100%);
  color: #ffffff;
}

.coupon-btn {
  background-color: #ffffff;
  color: #ff6347;
  border: 2rpx solid #ff6347;
}

.history-section {
  background-color: #ffffff;
  margin: 0 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.tabs {
  display: flex;
  border-bottom: 1rpx solid #eeeeee;
  margin-bottom: 20rpx;
}

.tab {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 72rpx;
  position: relative;
}

.tab-text {
  font-size: 26rpx;
  color: #999999;
}

.tab.active .tab-text {
  color: #ff6347;
  font-weight: bold;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 50rpx;
  height: 4rpx;
  background-color: #ff6347;
  border-radius: 2rpx;
}

.history-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.loading-view,
.empty-view {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
}

.empty-text {
  font-size: 26rpx;
  color: #999999;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.history-item:last-child {
  border-bottom: none;
}

.history-left {
  display: flex;
  flex-direction: column;
}

.history-title {
  font-size: 26rpx;
  color: #333333;
  margin-bottom: 6rpx;
}

.history-time {
  font-size: 22rpx;
  color: #999999;
}

.history-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.history-change {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 4rpx;
}

.history-right.earn .history-change,
.history-right.reward .history-change {
  color: #ff6347;
}

.history-right.spend .history-change,
.history-right.expire .history-change {
  color: #666666;
}

.history-type {
  font-size: 22rpx;
  color: #999999;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  justify-content: center;
  align-items: flex-end;
}

.redeem-modal {
  width: 100%;
  max-height: 80vh;
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.modal-close {
  font-size: 48rpx;
  color: #999999;
  line-height: 1;
}

.modal-balance {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background-color: #fff5f5;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.balance-tip {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.balance-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff6347;
}

.reward-list {
  margin-bottom: 24rpx;
}

.reward-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.reward-item.selected {
  border-color: #ff6347;
  background-color: #fff5f5;
}

.reward-info {
  display: flex;
  flex-direction: column;
}

.reward-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 6rpx;
}

.reward-desc {
  font-size: 24rpx;
  color: #666666;
}

.reward-points {
  display: flex;
  align-items: baseline;
}

.points-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6347;
}

.points-unit {
  font-size: 22rpx;
  color: #ff6347;
  margin-left: 4rpx;
}

.confirm-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #ff6347 0%, #ff7f50 100%);
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 30rpx;
  text-align: center;
}
