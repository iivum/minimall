.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.new-user-section {
  padding: 20rpx;
}

.new-user-coupon {
  display: flex;
  background: linear-gradient(135deg, #ff6347 0%, #ff7f50 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  overflow: hidden;
}

.coupon-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-right: 20rpx;
  border-right: 2rpx dashed rgba(255, 255, 255, 0.5);
  min-width: 140rpx;
}

.coupon-amount {
  font-size: 60rpx;
  font-weight: bold;
  color: #ffffff;
  line-height: 1;
}

.coupon-yuan {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 4rpx;
}

.coupon-right {
  flex: 1;
  padding-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.coupon-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.coupon-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 6rpx;
}

.coupon-min {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
}

.coupon-action {
  display: flex;
  align-items: center;
  padding-left: 20rpx;
}

.claim-btn {
  padding: 16rpx 24rpx;
  background-color: #ffffff;
  color: #ff6347;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: bold;
}

.claimed-text,
.expired-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.new-user-tip {
  text-align: center;
  font-size: 22rpx;
  color: #ff6347;
  margin-top: 10rpx;
}

.share-banner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 0 20rpx 20rpx;
  padding: 24rpx;
  background-color: #fff9e6;
  border-radius: 12rpx;
  border: 2rpx solid #ffd700;
}

.banner-left {
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #8b4513;
  margin-bottom: 6rpx;
}

.banner-desc {
  font-size: 22rpx;
  color: #b8860b;
}

.banner-arrow {
  font-size: 28rpx;
  color: #b8860b;
}

.tabs-section {
  display: flex;
  background-color: #ffffff;
  padding: 0 20rpx;
  border-bottom: 1rpx solid #eeeeee;
}

.tab-item {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 88rpx;
  position: relative;
}

.tab-text {
  font-size: 28rpx;
  color: #999999;
}

.tab-item.active .tab-text {
  color: #ff6347;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #ff6347;
  border-radius: 2rpx;
}

.coupon-list {
  padding: 20rpx;
}

.loading-view,
.empty-view {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.coupon-item {
  display: flex;
  background-color: #ffffff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  position: relative;
}

.coupon-item.used,
.coupon-item.expired {
  opacity: 0.6;
}

.coupon-item.used::after,
.coupon-item.expired::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.05);
}

.coupon-item-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 160rpx;
  padding: 24rpx;
  background-color: #fff5f5;
  border-right: 2rpx dashed #ffcccc;
}

.item-amount {
  font-size: 44rpx;
  font-weight: bold;
  color: #ff6347;
  line-height: 1;
}

.item-yuan {
  font-size: 22rpx;
  color: #ff6347;
  margin-top: 4rpx;
}

.coupon-item-right {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.item-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 6rpx;
}

.item-desc {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 4rpx;
}

.item-min {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 4rpx;
}

.item-time {
  font-size: 22rpx;
  color: #999999;
}

.expiring-tip {
  position: absolute;
  top: 10rpx;
  right: 120rpx;
  background-color: #ff6347;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.expiring-tip text {
  font-size: 20rpx;
  color: #ffffff;
}

.coupon-item-status {
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  background-color: #ff6347;
}

.status-text {
  font-size: 24rpx;
  color: #ffffff;
  white-space: nowrap;
}

.status-text.used,
.status-text.expired {
  color: rgba(255, 255, 255, 0.7);
}

.bottom-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
}

.bottom-tip text {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.8;
}
