.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.share-header {
  background: linear-gradient(135deg, #ff6347 0%, #ff7f50 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.share-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.share-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.poster-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.poster-container {
  position: relative;
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.poster-image {
  width: 500rpx;
  height: 800rpx;
  border-radius: 12rpx;
  background-color: #f0f0f0;
}

.poster-overlay {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 500rpx;
  height: 800rpx;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 12rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.generating-text {
  color: #ffffff;
  font-size: 28rpx;
}

.action-section {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  text-align: center;
}

.save-btn {
  background-color: #ffffff;
  color: #ff6347;
  border: 2rpx solid #ff6347;
}

.share-btn {
  background: linear-gradient(135deg, #ff6347 0%, #ff7f50 100%);
  color: #ffffff;
}

.statistics-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.statistics-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.statistics-list {
  display: flex;
  justify-content: space-around;
}

.statistics-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.statistics-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff6347;
  margin-bottom: 8rpx;
}

.statistics-label {
  font-size: 24rpx;
  color: #999999;
}

.reward-section {
  background: linear-gradient(135deg, #ffd700 0%, #ffb347 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.reward-info {
  text-align: center;
  margin-bottom: 20rpx;
}

.reward-text {
  display: block;
  font-size: 28rpx;
  color: #8b4513;
  margin-bottom: 8rpx;
}

.reward-amount {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #8b4513;
}

.claim-btn {
  width: 300rpx;
  height: 72rpx;
  line-height: 72rpx;
  background-color: #8b4513;
  color: #ffffff;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.tips-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.tips-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
}

.tips-item {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 10rpx;
}

.nav-section {
  background-color: #ffffff;
  border-radius: 16rpx;
}

.nav-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
}

.nav-text {
  font-size: 28rpx;
  color: #333333;
}

.nav-arrow {
  font-size: 28rpx;
  color: #999999;
}
