<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  MiniMall Logging Specification Configuration

  Log Level Rules:
  - log.error: Only for genuine error conditions (exceptions, failures)
  - log.warn:  For warning conditions (recoverable issues, invalid inputs)
  - log.info:  For significant business events (order created, payment success)
  - log.debug: For debugging information (token refresh, cache hits)

  Acceptable log.error scenarios:
  1. External API call failures (WeChat Pay, WeChat Subscribe)
  2. Signature/Security verification failures
  3. Critical callback processing failures
  4. Unexpected exceptions in service methods

  NOT acceptable:
  - log.error for business logic flow (use log.warn or log.info)
  - log.error for expected validation failures
  - log.error without proper context/metadata
-->
<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="warning"/>
    <property name="fileExtensions" value="java"/>

    <module name="TreeWalker">
        <module name="AvoidStarImport"/>
        <module name="EmptyStatement"/>
        <module name="LeftCurly"/>
        <module name="NeedBraces"/>
        <module name="RightCurly"/>
    </module>

    <module name="LineLength">
        <property name="max" value="120"/>
    </module>
    <module name="NewlineAtEndOfFile"/>
</module>