<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  MiniMall Checkstyle Configuration
-->
<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="warning"/>
    <property name="fileExtensions" value="java"/>

    <module name="TreeWalker">
        <module name="AvoidStarImport"/>
        <module name="EmptyStatement"/>
        <module name="LeftCurly"/>
        <module name="NeedBraces"/>
        <module name="RightCurly"/>
        <!-- Required Java style rules -->
        <module name="FinalParameters"/>
        <module name="OneStatementPerLine"/>
        <module name="WhitespaceAfter"/>
    </module>

    <!-- Logging checks at Checker level -->
    <module name="RegexpSingleline">
        <!--
          Pattern: log\.error\(.*(?:getMessage\(\)|e\.getMessage\(\))
          Severity: warning
          Description: Prefer logging full exception with cause over just getMessage()
          Rationale: Full exception stack trace provides better debugging context
        -->
        <property name="format" value="log\.error\([^,]+,\s*(?:e\.getMessage\(\)|getMessage\(\))\)"/>
        <property name="message" value="Use 'log.error(&quot;msg&quot;, ex)' or 'log.error(&quot;msg&quot;, e)' to log full exception with stack trace"/>
        <property name="ignoreCase" value="false"/>
    </module>

    <module name="RegexpSingleline">
        <!--
          Pattern: log\.error\(.*&quot;[^&quot;]*error[^&quot;]*&quot;
          Severity: info (not error)
          Description: Error log messages should describe the failure context, not contain the word "error"
          Rationale: The log level (error) already indicates it's an error
        -->
        <property name="format" value="log\.error\(&quot;[^&quot;]*\berror\b[^&quot;]*&quot;"/>
        <property name="message" value="Error log message should describe what failed, not contain the word 'error'. Use 'log.error(&quot;Failed to sign request: {}&quot;, e)'"/>
        <property name="ignoreCase" value="true"/>
    </module>

    <module name="RegexpSingleline">
        <!--
          Pattern: log\.error\(.*\)\s*;?\s*$ (empty or no message)
          Severity: error
          Description: log.error requires a message
          Rationale: Empty error logs provide no context
        -->
        <property name="format" value="log\.error\(\s*\)"/>
        <property name="message" value="log.error() requires a message describing the error context"/>
        <property name="ignoreCase" value="false"/>
    </module>

    <module name="LineLength">
        <property name="max" value="120"/>
    </module>
    <module name="NewlineAtEndOfFile"/>
</module>