.product-card { background: #fff; border-radius: 12rpx; overflow: hidden; }
.product-image { width: 100%; height: 300rpx; background: #f5f5f5; }
.product-info { padding: 16rpx; }
.product-name { font-size: 26rpx; color: #333; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 12rpx; }
.product-bottom { display: flex; align-items: baseline; }
.product-price { color: #ff6347; font-size: 28rpx; font-weight: bold; }
.product-original { color: #999; font-size: 22rpx; text-decoration: line-through; margin-left: 8rpx; }
