.cart-item { display: flex; align-items: center; padding: 24rpx; background: #fff; margin-bottom: 2rpx; position: relative; }
.item-image { width: 160rpx; height: 160rpx; border-radius: 12rpx; margin: 0 20rpx; background: #f5f5f5; }
.item-info { flex: 1; }
.item-name { font-size: 28rpx; color: #333; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 12rpx; }
.item-bottom { display: flex; align-items: center; justify-content: space-between; }
.item-price { color: #ff6347; font-size: 30rpx; font-weight: bold; }
.count-control { display: flex; align-items: center; gap: 16rpx; }
.count-control text { width: 40rpx; height: 40rpx; border: 1px solid #ddd; display: flex; align-items: center; justify-content: center; font-size: 24rpx; }
.count { min-width: 40rpx; text-align: center; }
.btn-delete { position: absolute; right: 24rpx; bottom: 24rpx; color: #ff6347; font-size: 24rpx; }
