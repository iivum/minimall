.room-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #000;
  position: relative;
}

.video-area {
  position: relative;
  width: 100%;
  height: 500rpx;
}

.video-player {
  width: 100%;
  height: 100%;
}

.video-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.host-info {
  display: flex;
  align-items: center;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 30rpx;
  padding: 10rpx 20rpx;
}

.host-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.host-name {
  color: #fff;
  font-size: 26rpx;
}

.viewer-count {
  background-color: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
}

.goods-drawer {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 50vh;
  background-color: var(--color-bg-card);
  border-radius: 24rpx 24rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s;
  z-index: 100;
}

.goods-drawer.show {
  transform: translateY(0);
}

.goods-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.goods-title {
  font-size: 32rpx;
  font-weight: 600;
}

.close-btn {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--color-text-tertiary);
}

.goods-scroll {
  height: calc(50vh - 100rpx);
}

.goods-item {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid var(--color-bg-page);
}

.goods-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-medium);
  margin-right: 20rpx;
}

.goods-info {
  flex: 1;
}

.goods-name {
  font-size: 28rpx;
  color: var(--color-text-primary);
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-price {
  font-size: 32rpx;
  color: var(--color-primary);
  font-weight: 600;
}

.goods-action {
  background-color: var(--color-success);
  color: #fff;
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.interaction-area {
  position: absolute;
  bottom: 200rpx;
  right: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.goods-btn,
.like-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 22rpx;
}

.like-btn.liked .like-icon {
  color: var(--color-primary);
}

.like-icon {
  font-size: 32rpx;
}

.like-count {
  font-size: 18rpx;
}

.comments-area {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 120rpx;
  height: 200rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.5));
  padding: 20rpx;
}

.comments-scroll {
  height: 120rpx;
}

.comment-item {
  color: #fff;
  font-size: 26rpx;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.comment-user {
  color: var(--color-success);
  margin-right: 8rpx;
}

.comment-input-area {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.comment-input {
  flex: 1;
  height: 64rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 32rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
}

.send-btn {
  width: 100rpx;
  height: 64rpx;
  line-height: 64rpx;
  background-color: var(--color-success);
  color: #fff;
  font-size: 26rpx;
  border-radius: 32rpx;
  padding: 0;
  margin: 0;
}
