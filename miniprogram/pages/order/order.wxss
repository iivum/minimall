.container { background: #f5f5f5; min-height: 100vh; }
.tab-bar { display: flex; background: #fff; height: 88rpx; }
.tab-item { flex: 1; display: flex; align-items: center; justify-content: center; font-size: 28rpx; color: #666; position: relative; }
.tab-item.active { color: #ff6347; font-weight: bold; }
.tab-item.active::after { content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 48rpx; height: 4rpx; background: #ff6347; border-radius: 2rpx; }
.order-list { padding: 20rpx 24rpx; }
.order-card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; }
.order-header { display: flex; justify-content: space-between; margin-bottom: 20rpx; }
.order-id { font-size: 26rpx; color: #999; }
.order-status { font-size: 28rpx; color: #ff6347; }
.order-goods { border-bottom: 1px solid #f5f5f5; padding-bottom: 20rpx; margin-bottom: 20rpx; }
.good-item { display: flex; margin-bottom: 16rpx; }
.good-image { width: 140rpx; height: 140rpx; border-radius: 12rpx; background: #f5f5f5; margin-right: 16rpx; }
.good-info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; }
.good-name { font-size: 28rpx; color: #333; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.good-price-row { display: flex; justify-content: space-between; align-items: baseline; }
.good-price { color: #333; font-size: 28rpx; }
.good-count { color: #999; font-size: 26rpx; }
.order-footer { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.order-time { font-size: 24rpx; color: #999; }
.order-total { display: flex; align-items: baseline; gap: 8rpx; font-size: 26rpx; color: #333; }
.total-price { color: #ff6347; font-size: 32rpx; font-weight: bold; }
.order-actions { display: flex; justify-content: flex-end; gap: 16rpx; }
.btn-pay { background: #ff6347; color: #fff; padding: 12rpx 32rpx; border-radius: 32rpx; font-size: 26rpx; }
.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 200rpx 0; color: #999; font-size: 28rpx; }
