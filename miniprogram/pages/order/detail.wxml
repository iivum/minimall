<!-- pages/order/detail.wxml -->
<view class="container" wx:if="{{!loading && order}}">
  <view class="order-status-bar">
    <text class="status-text status-{{order.status}}">{{order.statusText}}</text>
    <text class="status-desc">{{order.statusDesc}}</text>
  </view>
  <view class="card order-info">
    <text class="section-title">订单信息</text>
    <view class="info-row"><text>订单号:</text><text>{{order.orderNo}}</text></view>
    <view class="info-row"><text>下单时间:</text><text>{{order.createdAt}}</text></view>
  </view>
  <view class="card order-products">
    <text class="section-title">商品列表</text>
    <view class="product-item" wx:for="{{order.items}}" wx:key="id">
      <image class="product-img" src="{{item.imageUrl}}" />
      <view class="product-detail">
        <text class="product-name">{{item.name}}</text>
        <text class="product-price">¥{{item.price}}</text>
      </view>
      <text class="product-qty">x{{item.quantity}}</text>
    </view>
  </view>
  <view class="card order-total">
    <view class="total-row"><text>商品总额</text><text>¥{{order.totalAmount}}</text></view>
    <view class="total-row"><text>运费</text><text>¥0</text></view>
    <view class="total-row final"><text>合计</text><text class="total-price">¥{{order.totalAmount}}</text></view>
  </view>
  <view class="action-bar" wx:if="{{order.status === 'PENDING'}}">
    <button class="btn-cancel" bindtap="cancelOrder">取消订单</button>
    <button class="btn-pay" bindtap="payOrder">去支付</button>
  </view>
</view>
<view class="loading" wx:if="{{loading}}"><text>加载中...</text></view>