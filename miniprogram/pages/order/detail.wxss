/* pages/order/detail.wxss */
.order-status-bar { background-color: #FF6B6B; color: #fff; padding: 48rpx 24rpx; text-align: center; }
.status-text { font-size: 36rpx; font-weight: bold; display: block; }
.status-desc { font-size: 24rpx; opacity: 0.8; margin-top: 8rpx; }
.card { margin: 24rpx; background-color: #fff; border-radius: 12rpx; padding: 24rpx; }
.section-title { font-size: 32rpx; font-weight: bold; display: block; margin-bottom: 16rpx; }
.info-row { display: flex; justify-content: space-between; padding: 8rpx 0; font-size: 28rpx; color: #666; }
.product-item { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.product-item:last-child { border-bottom: none; }
.product-img { width: 120rpx; height: 120rpx; border-radius: 8rpx; }
.product-detail { flex: 1; margin-left: 16rpx; }
.product-name { font-size: 28rpx; display: block; }
.product-price { color: #FF6B6B; font-size: 28rpx; margin-top: 8rpx; display: block; }
.product-qty { color: #999; font-size: 24rpx; }
.total-row { display: flex; justify-content: space-between; padding: 16rpx 0; font-size: 28rpx; }
.total-row.final { border-top: 1rpx solid #f0f0f0; margin-top: 8rpx; padding-top: 24rpx; font-weight: bold; }
.total-price { color: #FF6B6B; font-size: 40rpx; }
.action-bar { position: fixed; bottom: 0; left: 0; right: 0; display: flex; gap: 24rpx; padding: 24rpx; background-color: #fff; border-top: 1rpx solid #eee; }
.btn-cancel { flex: 1; background-color: #fff; color: #666; border: 1rpx solid #ddd; border-radius: 48rpx; }
.btn-pay { flex: 1; background-color: #FF6B6B; color: #fff; border-radius: 48rpx; }
.loading { text-align: center; padding: 100rpx 0; color: #999; }