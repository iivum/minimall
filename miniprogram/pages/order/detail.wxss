/* pages/order/detail.wxss */
.order-status-bar { background-color: var(--color-primary); color: #fff; padding: 48rpx 24rpx; text-align: center; }
.status-text { font-size: 36rpx; font-weight: bold; display: block; }
.status-desc { font-size: 24rpx; opacity: 0.8; margin-top: 8rpx; }
.card { margin: 24rpx; background-color: var(--color-bg-card); border-radius: var(--radius-medium); padding: 24rpx; }
.section-title { font-size: 32rpx; font-weight: bold; display: block; margin-bottom: 16rpx; }
.info-row { display: flex; justify-content: space-between; padding: 8rpx 0; font-size: 28rpx; color: var(--color-text-secondary); }
.product-item { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid var(--color-border-lighter); }
.product-item:last-child { border-bottom: none; }
.product-img { width: 120rpx; height: 120rpx; border-radius: var(--radius-small); }
.product-detail { flex: 1; margin-left: 16rpx; }
.product-name { font-size: 28rpx; display: block; }
.product-price { color: var(--color-primary); font-size: 28rpx; margin-top: 8rpx; display: block; }
.product-qty { color: var(--color-text-tertiary); font-size: 24rpx; }
.total-row { display: flex; justify-content: space-between; padding: 16rpx 0; font-size: 28rpx; }
.total-row.final { border-top: 1rpx solid var(--color-border-lighter); margin-top: 8rpx; padding-top: 24rpx; font-weight: bold; }
.total-price { color: var(--color-primary); font-size: 40rpx; }
.action-bar { position: fixed; bottom: 0; left: 0; right: 0; display: flex; gap: 24rpx; padding: 24rpx; background-color: var(--color-bg-card); border-top: 1rpx solid var(--color-border-light); }
.btn-cancel { flex: 1; background-color: var(--color-bg-card); color: var(--color-text-secondary); border: 1rpx solid var(--color-border); border-radius: var(--radius-large); }
.btn-pay { flex: 1; background-color: var(--color-primary); color: #fff; border-radius: var(--radius-large); }
.loading { text-align: center; padding: 100rpx 0; color: var(--color-text-tertiary); }