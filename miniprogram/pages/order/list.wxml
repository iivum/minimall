<!-- pages/order/list.wxml -->
<view class="container">
  <!-- 订单列表 -->
  <view class="order-list" wx:if="{{!loading && orders.length > 0}}">
    <view class="order-item card" wx:for="{{orders}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}" hover-class="item-press">
      <view class="order-header">
        <text class="order-no">订单号: {{item.orderNo}}</text>
        <text class="order-status status-{{item.status}}">{{item.statusText}}</text>
      </view>
      <view class="order-products">
        <view class="product-item" wx:for="{{item.items}}" wx:for-item="product" wx:key="id">
          <text class="product-name">{{product.name}}</text>
          <text class="product-qty">x{{product.quantity}}</text>
        </view>
      </view>
      <view class="order-footer">
        <text class="order-time">{{item.createdAt}}</text>
        <view class="order-total">
          <text class="total-label">合计:</text>
          <text class="total-price">¥{{item.totalAmount}}</text>
        </view>
      </view>
    </view>
  </view>
  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>
  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && orders.length === 0}}">
    <image class="empty-icon" src="/assets/images/empty-order.png" mode="aspectFit" />
    <text class="empty-text">暂无订单</text>
    <text class="empty-hint">快去下单吧</text>
    <button class="btn-primary" bindtap="goShopping">去购物</button>
  </view>
</view>