/* pages/pay/pay.wxss */
.pay-info { text-align: center; padding: 48rpx 24rpx; }
.pay-title { font-size: 28rpx; color: var(--color-text-secondary); display: block; margin-bottom: 24rpx; }
.pay-amount { display: flex; justify-content: center; align-items: baseline; }
.currency { font-size: 36rpx; color: var(--color-text-primary); }
.amount { font-size: 72rpx; font-weight: bold; color: var(--color-text-primary); }
.pay-method { display: flex; align-items: center; padding: 32rpx 24rpx; }
.wechat-icon { width: 48rpx; height: 48rpx; }
.method-name { flex: 1; margin-left: 16rpx; font-size: 32rpx; }
.check-icon { color: var(--color-success); font-size: 36rpx; }
.pay-btn { margin-top: 48rpx; padding: 0 24rpx; }
.btn-confirm { background-color: var(--color-success); color: #fff; border-radius: var(--radius-large); height: 96rpx; line-height: 96rpx; font-size: 36rpx; }
.btn-disabled { background-color: var(--color-bg-disabled); }