/* pages/pay/pay.wxss */
.pay-info { text-align: center; padding: 48rpx 24rpx; }
.pay-title { font-size: 28rpx; color: #666; display: block; margin-bottom: 24rpx; }
.pay-amount { display: flex; justify-content: center; align-items: baseline; }
.currency { font-size: 36rpx; color: #333; }
.amount { font-size: 72rpx; font-weight: bold; color: #333; }
.pay-method { display: flex; align-items: center; padding: 32rpx 24rpx; }
.wechat-icon { width: 48rpx; height: 48rpx; }
.method-name { flex: 1; margin-left: 16rpx; font-size: 32rpx; }
.check-icon { color: #07C160; font-size: 36rpx; }
.pay-btn { margin-top: 48rpx; padding: 0 24rpx; }
.btn-confirm { background-color: #07C160; color: #fff; border-radius: 48rpx; height: 96rpx; line-height: 96rpx; font-size: 36rpx; }
.btn-disabled { background-color: #ccc; }