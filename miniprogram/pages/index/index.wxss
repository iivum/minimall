/* pages/index/index.wxss */
.search-bar { background-color: #fff; padding: 20rpx 24rpx; }
.search-input { background-color: #f5f5f5; border-radius: 32rpx; padding: 16rpx 32rpx; font-size: 28rpx; }
.product-list { display: flex; flex-direction: column; padding: 24rpx; }
.product-item { background-color: #fff; border-radius: 12rpx; margin-bottom: 24rpx; overflow: hidden; display: flex; flex-direction: row; }
.product-image { width: 240rpx; height: 240rpx; }
.product-info { flex: 1; padding: 24rpx; display: flex; flex-direction: column; justify-content: space-between; }
.product-name { font-size: 32rpx; font-weight: bold; color: #333; margin-bottom: 8rpx; }
.product-desc { font-size: 24rpx; color: #999; margin-bottom: 8rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.product-price { display: flex; align-items: center; gap: 16rpx; }
.price { color: #FF6B6B; font-size: 36rpx; font-weight: bold; }
.original-price { color: #999; font-size: 24rpx; text-decoration: line-through; }
.product-actions { display: flex; justify-content: flex-end; margin-top: 16rpx; }
.btn-add-cart { background-color: #FF6B6B; color: #fff; font-size: 24rpx; padding: 8rpx 24rpx; border-radius: 32rpx; }
.loading, .empty { text-align: center; padding: 100rpx 0; color: #999; }