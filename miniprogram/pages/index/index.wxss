.search-bar {
  margin: 20rpx 24rpx;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.search-placeholder {
  color: #999;
  font-size: 28rpx;
}
.banner-swiper {
  width: 100%;
  height: 320rpx;
}
.banner-image {
  width: 100%;
  height: 100%;
}
.category-nav {
  display: flex;
  flex-wrap: wrap;
  padding: 24rpx;
  background: #fff;
}
.category-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}
.category-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}
.category-name {
  font-size: 24rpx;
  color: #666;
}
.section {
  margin-top: 20rpx;
  background: #fff;
  padding: 24rpx;
}
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.flash-timer {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.timer-label {
  font-size: 24rpx;
  color: #999;
}
.timer-value {
  font-size: 26rpx;
  color: #ff6347;
  font-weight: bold;
}
.goods-scroll {
  white-space: nowrap;
  width: 100%;
}
.goods-card {
  display: inline-block;
  vertical-align: top;
  margin-right: 20rpx;
}
.goods-card.small {
  width: 200rpx;
}
.goods-card {
  width: 330rpx;
  background: #fff;
}
.goods-image {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}
.goods-card.small .goods-image {
  height: 200rpx;
}
.goods-info {
  padding: 12rpx 0;
}
.goods-name {
  font-size: 26rpx;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 8rpx;
}
.goods-price {
  color: #ff6347;
  font-size: 28rpx;
  font-weight: bold;
}
.goods-original-price {
  color: #999;
  font-size: 22rpx;
  text-decoration: line-through;
  margin-left: 8rpx;
}
.goods-price-row {
  display: flex;
  align-items: baseline;
  margin-top: 8rpx;
}
.goods-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
