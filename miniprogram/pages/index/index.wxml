<!-- pages/index/index.wxml -->
<view class="container">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索商品" bindconfirm="onSearch" confirm-type="search" />
  </view>
  <!-- 骨架屏加载状态 -->
  <view class="skeleton-list" wx:if="{{loading}}">
    <view class="skeleton-item" wx:for="{{[1,2,3,4]}}" wx:key="index">
      <view class="skeleton-image"></view>
      <view class="skeleton-content">
        <view class="skeleton-title"></view>
        <view class="skeleton-desc"></view>
        <view class="skeleton-price"></view>
      </view>
    </view>
  </view>
  <!-- 商品列表 -->
  <view class="product-list" wx:if="{{!loading && products.length > 0}}">
    <view class="product-item" wx:for="{{products}}" wx:key="id" bindtap="goToProduct" data-id="{{item.id}}" hover-class="item-press">
      <image class="product-image" mode="aspectFill" src="{{item.imageUrl}}" />
      <view class="product-info">
        <text class="product-name">{{item.name}}</text>
        <view class="product-desc">{{item.description}}</view>
        <view class="product-price">
          <text class="price">¥{{item.price}}</text>
          <text class="original-price" wx:if="{{item.originalPrice > item.price}}">¥{{item.originalPrice}}</text>
        </view>
        <view class="product-actions">
          <button class="btn-add-cart" size="mini" catchtap="addToCart" data-id="{{item.id}}">加入购物车</button>
        </view>
      </view>
    </view>
  </view>
  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading && products.length === 0}}">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>
  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && products.length === 0}}">
    <image class="empty-icon" src="/assets/images/empty-product.png" mode="aspectFit" />
    <text class="empty-text">暂无商品</text>
    <text class="empty-hint">看看其他商品吧</text>
  </view>
</view>