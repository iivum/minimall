/* pages/product/detail.wxss */
.product-image { width: 100%; height: 600rpx; }
.product-info { margin-top: 24rpx; }
.product-name { font-size: 36rpx; font-weight: bold; display: block; margin-bottom: 16rpx; }
.price-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.price { color: var(--color-primary); font-size: 40rpx; font-weight: bold; }
.original-price { color: var(--color-text-tertiary); font-size: 28rpx; text-decoration: line-through; }
.product-desc { font-size: 28rpx; color: var(--color-text-secondary); line-height: 1.6; }
.quantity-row { display: flex; justify-content: space-between; align-items: center; }
.quantity-control { display: flex; align-items: center; gap: 16rpx; }
.quantity-control button { width: 60rpx; height: 60rpx; line-height: 60rpx; background-color: var(--color-bg-input); border-radius: var(--radius-small); }
.quantity-control input { width: 80rpx; text-align: center; border: 1rpx solid var(--color-border); border-radius: var(--radius-small); }
.action-bar { position: fixed; bottom: 0; left: 0; right: 0; display: flex; gap: 24rpx; padding: 24rpx; background-color: var(--color-bg-card); }
.btn-primary { flex: 1; background-color: var(--color-primary); color: #fff; border-radius: var(--radius-large); }
.btn-secondary { flex: 1; background-color: var(--color-bg-card); color: var(--color-text-primary); border: 1rpx solid var(--color-border); border-radius: var(--radius-large); }
.loading { text-align: center; padding: 100rpx 0; color: var(--color-text-tertiary); }