/* pages/product/detail.wxss */
.product-image { width: 100%; height: 600rpx; }
.product-info { margin-top: 24rpx; }
.product-name { font-size: 36rpx; font-weight: bold; display: block; margin-bottom: 16rpx; }
.price-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.price { color: #FF6B6B; font-size: 40rpx; font-weight: bold; }
.original-price { color: #999; font-size: 28rpx; text-decoration: line-through; }
.product-desc { font-size: 28rpx; color: #666; line-height: 1.6; }
.quantity-row { display: flex; justify-content: space-between; align-items: center; }
.quantity-control { display: flex; align-items: center; gap: 16rpx; }
.quantity-control button { width: 60rpx; height: 60rpx; line-height: 60rpx; background-color: #f5f5f5; border-radius: 8rpx; }
.quantity-control input { width: 80rpx; text-align: center; border: 1rpx solid #ddd; border-radius: 8rpx; }
.action-bar { position: fixed; bottom: 0; left: 0; right: 0; display: flex; gap: 24rpx; padding: 24rpx; background-color: #fff; }
.btn-primary { flex: 1; background-color: #FF6B6B; color: #fff; border-radius: 48rpx; }
.btn-secondary { flex: 1; background-color: #fff; color: #333; border: 1rpx solid #ddd; border-radius: 48rpx; }
.loading { text-align: center; padding: 100rpx 0; color: #999; }