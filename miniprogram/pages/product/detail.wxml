<!-- pages/product/detail.wxml -->
<view class="container" wx:if="{{!loading && product}}">
  <image class="product-image" mode="aspectFill" src="{{product.imageUrl}}" />
  <view class="product-info card">
    <text class="product-name">{{product.name}}</text>
    <view class="price-row">
      <text class="price">¥{{product.price}}</text>
      <text class="original-price" wx:if="{{product.originalPrice > product.price}}">¥{{product.originalPrice}}</text>
    </view>
    <text class="product-desc">{{product.description}}</text>
  </view>
  <view class="quantity-row card">
    <text class="quantity-label">数量</text>
    <view class="quantity-control">
      <view class="quantity-btn minus {{quantity <= 1 ? 'disabled' : ''}}" bindtap="onQuantityChange" data-type="minus">-</view>
      <input class="quantity-input" type="number" value="{{quantity}}" bindchange="onQuantityChange" />
      <view class="quantity-btn plus" bindtap="onQuantityChange" data-type="plus">+</view>
    </view>
  </view>
  <!-- 错误状态 -->
  <view class="error-panel" wx:if="{{error}}">
    <text class="error-text">{{error}}</text>
    <view class="btn-retry" bindtap="retryLoad">重新加载</view>
  </view>
</view>
<!-- 骨架屏加载状态 -->
<view class="skeleton-container" wx:if="{{loading && !product}}">
  <view class="skeleton-image"></view>
  <view class="skeleton-info">
    <view class="skeleton-title"></view>
    <view class="skeleton-price"></view>
    <view class="skeleton-desc"></view>
    <view class="skeleton-desc short"></view>
  </view>
</view>
<!-- 底部操作栏 -->
<view class="action-bar" wx:if="{{product && !error}}">
  <view class="action-left">
    <view class="btn-cart" bindtap="goToCart">
      <image class="cart-icon" src="/assets/images/tab-cart.png" />
    </view>
  </view>
  <view class="action-right">
    <view class="btn-secondary" bindtap="addToCart" hover-class="btn-press">加入购物车</view>
    <view class="btn-primary" bindtap="buyNow" hover-class="btn-press">立即购买</view>
  </view>
</view>