.container {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding: 24rpx;
}

.points-card {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
  border-radius: var(--radius-medium);
  padding: 40rpx;
  color: #fff;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

.points-label {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 8rpx;
}

.points-balance {
  font-size: 64rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: var(--color-text-tertiary);
  font-size: 28rpx;
}

.error-state {
  text-align: center;
  padding: 100rpx 0;
}

.error-text {
  display: block;
  color: var(--color-text-secondary);
  font-size: 28rpx;
  margin-bottom: 24rpx;
}

.retry-btn {
  width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.records-section {
  background: var(--color-bg-card);
  border-radius: var(--radius-medium);
  padding: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.records-list {
  display: flex;
  flex-direction: column;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-bg-page);
}

.record-item:last-child {
  border-bottom: none;
}

.record-info {
  flex: 1;
}

.record-title {
  font-size: 28rpx;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.record-time {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.record-points {
  font-size: 32rpx;
  font-weight: bold;
}

.record-points.positive {
  color: var(--color-primary);
}

.record-points.negative {
  color: var(--color-success);
}

.empty-state {
  text-align: center;
  padding: 60rpx 0;
  color: var(--color-text-tertiary);
  font-size: 28rpx;
}

.load-more {
  text-align: center;
  padding: 24rpx 0;
  color: var(--color-text-tertiary);
  font-size: 24rpx;
}