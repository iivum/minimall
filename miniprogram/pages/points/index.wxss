/* pages/points/index.wxss */
.points-header {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #fff;
  padding: 60rpx 32rpx 80rpx;
  text-align: center;
}
.points-label { font-size: 28rpx; opacity: 0.9; margin-bottom: 16rpx; }
.points-value { font-size: 72rpx; font-weight: bold; margin-bottom: 32rpx; }
.btn-exchange {
  background-color: #fff;
  color: #FF6B6B;
  border-radius: 48rpx;
  padding: 0 48rpx;
  height: 72rpx;
  line-height: 72rpx;
  display: inline-block;
}
.points-history { background-color: #fff; margin-top: -40rpx; border-radius: 32rpx 32rpx 0 0; padding: 32rpx; }
.history-title { font-size: 32rpx; font-weight: bold; margin-bottom: 24rpx; }
.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.item-info { display: flex; flex-direction: column; }
.item-type { font-size: 28rpx; margin-bottom: 8rpx; }
.item-date { font-size: 24rpx; color: #999; }
.item-points { font-size: 32rpx; font-weight: bold; }
.positive { color: #FF6B6B; }
.negative { color: #999; }
.empty { text-align: center; padding: 80rpx 0; color: #999; }