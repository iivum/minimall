.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 24rpx;
}

.points-card {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  border-radius: 16rpx;
  padding: 40rpx;
  color: #fff;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

.points-label {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 8rpx;
}

.points-balance {
  font-size: 64rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.error-state {
  text-align: center;
  padding: 100rpx 0;
}

.error-text {
  display: block;
  color: #666;
  font-size: 28rpx;
  margin-bottom: 24rpx;
}

.retry-btn {
  width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: #FF6B6B;
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.records-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #eee;
}

.records-list {
  display: flex;
  flex-direction: column;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-info {
  flex: 1;
}

.record-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.record-time {
  font-size: 24rpx;
  color: #999;
}

.record-points {
  font-size: 32rpx;
  font-weight: bold;
}

.record-points.positive {
  color: #FF6B6B;
}

.record-points.negative {
  color: #52c41a;
}

.empty-state {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.load-more {
  text-align: center;
  padding: 24rpx 0;
  color: #999;
  font-size: 24rpx;
}