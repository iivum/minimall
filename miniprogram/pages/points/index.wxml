<!-- pages/points/index.wxml -->
<view class="container">
  <view class="points-header">
    <text class="points-label">当前积分</text>
    <text class="points-value">{{points}}</text>
  </view>
  <view class="transactions-list">
    <block wx:for="{{transactions}}" wx:key="id">
      <view class="transaction-item">
        <view class="transaction-info">
          <text class="transaction-title">{{item.description}}</text>
          <text class="transaction-time">{{item.createdAt}}</text>
        </view>
        <text class="transaction-amount {{item.amount > 0 ? 'positive' : 'negative'}}">
          {{item.amount > 0 ? '+' : ''}}{{item.amount}}
        </text>
      </view>
    </block>
    <view wx:if="{{!loading && transactions.length === 0}}" class="empty">
      <text>暂无积分记录</text>
    </view>
  </view>
  <view class="loading" wx:if="{{loading}}"><text>加载中...</text></view>
</view>