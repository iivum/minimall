/* pages/points/record/index.wxss */
.points-header {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #fff;
  padding: 48rpx 24rpx;
  text-align: center;
}
.points-label {
  font-size: 28rpx;
  opacity: 0.9;
  display: block;
}
.points-value {
  font-size: 72rpx;
  font-weight: bold;
  display: block;
  margin: 16rpx 0;
}
.points-desc {
  font-size: 24rpx;
  opacity: 0.8;
  display: block;
}
.tabs {
  display: flex;
  background-color: #fff;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.tab {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  padding: 16rpx 0;
}
.tab.active {
  color: #FF6B6B;
  border-bottom: 4rpx solid #FF6B6B;
}
.history-list {
  padding: 0 24rpx;
}
.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.history-left {
  flex: 1;
}
.history-type {
  font-size: 28rpx;
  color: #333;
  display: block;
  font-weight: 500;
}
.history-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 8rpx;
}
.history-time {
  font-size: 22rpx;
  color: #ccc;
  display: block;
  margin-top: 8rpx;
}
.history-right {
  text-align: right;
}
.history-points {
  font-size: 36rpx;
  font-weight: bold;
}
.history-points.earn {
  color: #FF6B6B;
}
.history-points.spend {
  color: #999;
}
.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}