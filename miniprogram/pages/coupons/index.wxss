/* pages/coupons/index.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}
.coupon-tabs {
  display: flex;
  background-color: #fff;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.tab {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.tab.active {
  color: #FF6B6B;
}
.tab .count {
  background-color: #FF6B6B;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-top: 8rpx;
}
.coupon-list {
  padding: 24rpx;
}
.coupon-item {
  display: flex;
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}
.coupon-left {
  width: 200rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #fff;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.coupon-item.discount .coupon-left {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
}
.coupon-value {
  display: flex;
  align-items: baseline;
}
.currency {
  font-size: 28rpx;
  margin-right: 4rpx;
}
.amount {
  font-size: 56rpx;
  font-weight: bold;
}
.unit {
  font-size: 24rpx;
  margin-left: 4rpx;
}
.threshold {
  font-size: 22rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}
.coupon-right {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.coupon-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
.coupon-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
}
.coupon-action {
  margin-top: 16rpx;
}
.use-btn {
  background-color: #FF6B6B;
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
}
.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}