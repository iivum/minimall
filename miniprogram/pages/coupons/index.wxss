.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 20rpx;
}

.tab-item {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  position: relative;
}

.tab-item.active {
  color: #FF6B6B;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #FF6B6B;
  border-radius: 2rpx;
}

.coupon-list {
  padding: 20rpx;
}

.coupon-item {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.coupon-item.new-user {
  border: 2rpx solid #FF6B6B;
}

.coupon-left {
  width: 200rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx 20rpx;
}

.coupon-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
}

.coupon-unit {
  font-size: 24rpx;
  color: #fff;
  opacity: 0.9;
}

.coupon-right {
  flex: 1;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.coupon-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 10rpx;
}

.coupon-desc {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.coupon-time {
  font-size: 22rpx;
  color: #999;
}

.coupon-status {
  width: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.coupon-status.active {
  color: #FF6B6B;
}

.coupon-status.expired {
  color: #999;
}

.claim-btn {
  width: 140rpx;
  height: 56rpx;
  line-height: 56rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #fff;
  border-radius: 28rpx;
  font-size: 24rpx;
  margin: auto;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-inner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #fff;
  border-radius: 50%;
  border-top-color: transparent;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}