/* pages/coupons/index.wxss */
.tab-bar {
  display: flex;
  background-color: #fff;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}
.tab-item.active { color: #FF6B6B; font-weight: bold; }
.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background-color: #FF6B6B;
  border-radius: 2rpx;
}
.coupon-list { padding: 24rpx 32rpx; }
.coupon-item {
  display: flex;
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}
.coupon-item.used, .coupon-item.expired { opacity: 0.6; }
.coupon-left {
  width: 200rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #fff;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.coupon-value { display: flex; align-items: baseline; }
.value-number { font-size: 56rpx; font-weight: bold; }
.value-unit { font-size: 24rpx; margin-left: 4rpx; }
.coupon-condition { font-size: 20rpx; margin-top: 8rpx; opacity: 0.9; }
.coupon-right {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.coupon-name { font-size: 28rpx; font-weight: bold; margin-bottom: 8rpx; }
.coupon-desc { font-size: 24rpx; color: #666; margin-bottom: 8rpx; }
.coupon-date { font-size: 22rpx; color: #999; margin-bottom: 16rpx; }
.btn-get {
  background-color: #FF6B6B;
  color: #fff;
  border-radius: 32rpx;
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  width: 160rpx;
  text-align: center;
}
.coupon-status { font-size: 24rpx; color: #999; }
.empty { text-align: center; padding: 200rpx 0; color: #999; }
.empty button { margin-top: 32rpx; }