.container {
  min-height: 100vh;
  background-color: var(--color-bg-page);
}

.tab-bar {
  display: flex;
  background: var(--color-bg-card);
  padding: 0 24rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  position: relative;
}

.tab-item text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.tab-item.active text {
  color: var(--color-primary);
  font-weight: bold;
}

.tab-badge {
  position: absolute;
  top: 16rpx;
  right: 20rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
  text-align: center;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: var(--color-text-tertiary);
  font-size: 28rpx;
}

.error-state {
  text-align: center;
  padding: 100rpx 0;
}

.error-text {
  display: block;
  color: var(--color-text-secondary);
  font-size: 28rpx;
  margin-bottom: 24rpx;
}

.retry-btn {
  width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.coupons-list {
  padding: 24rpx;
}

.coupon-item {
  display: flex;
  background: var(--color-bg-card);
  border-radius: var(--radius-medium);
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.coupon-left {
  width: 200rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.coupon-left.used {
  background: var(--color-bg-disabled);
}

.coupon-left.expired {
  background: var(--color-text-tertiary);
}

.coupon-value {
  display: flex;
  align-items: baseline;
  color: #fff;
}

.coupon-unit {
  font-size: 28rpx;
  font-weight: bold;
}

.coupon-amount {
  font-size: 56rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}

.coupon-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  text-align: center;
}

.coupon-right {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.coupon-name {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: bold;
  margin-bottom: 8rpx;
}

.coupon-time {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 16rpx;
}

.coupon-action {
  width: 160rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  background: var(--color-primary);
  color: #fff;
  border-radius: 28rpx;
  font-size: 24rpx;
}

.coupon-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
  display: inline-block;
  width: fit-content;
}

.coupon-status.used {
  color: var(--color-text-tertiary);
  background: var(--color-bg-page);
}

.coupon-status.expired {
  color: var(--color-text-secondary);
  background: var(--color-border-light);
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-state text {
  display: block;
  color: var(--color-text-tertiary);
  font-size: 28rpx;
  margin-bottom: 24rpx;
}

.claim-btn {
  width: 240rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
}