<!-- pages/coupons/index.wxml -->
<view class="container">
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'available' ? 'active' : ''}}" data-tab="available" bindtap="onTabChange">
      <text>可领取</text>
    </view>
    <view class="tab-item {{activeTab === 'used' ? 'active' : ''}}" data-tab="used" bindtap="onTabChange">
      <text>已使用</text>
    </view>
    <view class="tab-item {{activeTab === 'expired' ? 'active' : ''}}" data-tab="expired" bindtap="onTabChange">
      <text>已过期</text>
    </view>
  </view>
  <view class="coupon-list" wx:if="{{coupons.length > 0}}">
    <view class="coupon-item {{coupon.status}}" wx:for="{{coupons}}" wx:key="id">
      <view class="coupon-left">
        <view class="coupon-value">
          <text class="value-number">{{coupon.value}}</text>
          <text class="value-unit">元</text>
        </view>
        <view class="coupon-condition">{{coupon.condition}}</view>
      </view>
      <view class="coupon-right">
        <view class="coupon-name">{{coupon.name}}</view>
        <view class="coupon-desc">{{coupon.desc}}</view>
        <view class="coupon-date">有效期至 {{coupon.expiryDate}}</view>
        <button class="btn-get" wx:if="{{coupon.status === 'available'}}" data-index="{{index}}" bindtap="getCoupon">立即领取</button>
        <view class="coupon-status" wx:if="{{coupon.status !== 'available'}}">{{coupon.status === 'used' ? '已使用' : '已过期'}}</view>
      </view>
    </view>
  </view>
  <view class="empty" wx:if="{{coupons.length === 0}}">
    <text>暂无优惠券</text>
    <button class="btn-shopping" bindtap="goShopping">去逛逛</button>
  </view>
</view>