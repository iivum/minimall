/* pages/member/index.wxss */
.user-header { display: flex; align-items: center; padding: 48rpx 24rpx; background-color: var(--color-primary); color: #fff; }
.avatar { width: 120rpx; height: 120rpx; border-radius: var(--radius-circle); background-color: var(--color-bg-card); }
.user-info { margin-left: 24rpx; flex: 1; }
.nickname { font-size: 36rpx; font-weight: bold; display: block; }
.phone { font-size: 24rpx; opacity: 0.8; display: block; margin-top: 8rpx; }
.member-card { display: flex; justify-content: space-between; margin-top: -40rpx; }
.member-title { font-size: 32rpx; font-weight: bold; color: var(--color-primary); display: block; }
.member-desc { font-size: 24rpx; color: var(--color-text-tertiary); margin-top: 8rpx; display: block; }
.member-right { text-align: right; }
.points-label { font-size: 24rpx; color: var(--color-text-tertiary); display: block; }
.points-value { font-size: 48rpx; font-weight: bold; color: var(--color-primary); display: block; }
.menu-list { background-color: var(--color-bg-card); border-radius: var(--radius-medium); margin: 24rpx 0; }
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 32rpx 24rpx; border-bottom: 1rpx solid var(--color-border-lighter); font-size: 28rpx; }
.menu-item:last-child { border-bottom: none; }
.arrow { color: var(--color-text-tertiary); }
.logout-btn { margin-top: 48rpx; }
.logout-btn button { background-color: var(--color-bg-card); color: var(--color-text-secondary); border: 1rpx solid var(--color-border); border-radius: var(--radius-small); }
.loading { text-align: center; padding: 100rpx 0; color: var(--color-text-tertiary); }