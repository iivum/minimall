/* pages/member/index.wxss */
.user-header { display: flex; align-items: center; padding: 48rpx 24rpx; background-color: #FF6B6B; color: #fff; }
.avatar { width: 120rpx; height: 120rpx; border-radius: 60rpx; background-color: #fff; }
.user-info { margin-left: 24rpx; flex: 1; }
.nickname { font-size: 36rpx; font-weight: bold; display: block; }
.phone { font-size: 24rpx; opacity: 0.8; display: block; margin-top: 8rpx; }
.member-card { display: flex; justify-content: space-between; margin-top: -40rpx; }
.member-title { font-size: 32rpx; font-weight: bold; color: #FF6B6B; display: block; }
.member-desc { font-size: 24rpx; color: #999; margin-top: 8rpx; display: block; }
.member-right { text-align: right; }
.points-label { font-size: 24rpx; color: #999; display: block; }
.points-value { font-size: 48rpx; font-weight: bold; color: #FF6B6B; display: block; }
.menu-list { background-color: #fff; border-radius: 12rpx; margin: 24rpx 0; }
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 32rpx 24rpx; border-bottom: 1rpx solid #f0f0f0; font-size: 28rpx; }
.menu-item:last-child { border-bottom: none; }
.arrow { color: #999; }
.logout-btn { margin-top: 48rpx; }
.logout-btn button { background-color: #fff; color: #666; border: 1rpx solid #ddd; border-radius: 8rpx; }
.loading { text-align: center; padding: 100rpx 0; color: #999; }