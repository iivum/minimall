<!-- pages/member/index.wxml -->
<view class="container" wx:if="{{!loading && userInfo}}">
  <view class="user-header">
    <image class="avatar" src="{{userInfo.avatarUrl || '/assets/images/default-avatar.png'}}" />
    <view class="user-info">
      <text class="nickname">{{userInfo.nickname || '微信用户'}}</text>
      <text class="phone">{{userInfo.phone || ''}}</text>
    </view>
  </view>
  <view class="member-card card">
    <view class="member-left">
      <text class="member-title">{{benefits?.memberGrade || '普通会员'}}</text>
      <text class="member-desc">享受更多权益</text>
    </view>
    <view class="member-right">
      <text class="points-label">积分</text>
      <text class="points-value">{{points}}</text>
    </view>
  </view>
  <view class="menu-list">
    <view class="menu-item" bindtap="goToOrders"><text>我的订单</text><text class="arrow">></text></view>
    <view class="menu-item" bindtap="goToCoupons"><text>优惠券</text><text class="arrow">></text></view>
    <view class="menu-item" bindtap="goToPoints"><text>积分记录</text><text class="arrow">></text></view>
    <view class="menu-item" bindtap="goToPrivacy"><text>隐私政策</text><text class="arrow">></text></view>
    <view class="menu-item" bindtap="goToAgreement"><text>用户协议</text><text class="arrow">></text></view>
  </view>
  <view class="logout-btn"><button bindtap="logout">退出登录</button></view>
</view>
<view class="loading" wx:if="{{loading}}"><text>加载中...</text></view>