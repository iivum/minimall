/* pages/cart/cart.wxss */
.cart-list { padding-bottom: 120rpx; }
.cart-item { display: flex; align-items: center; background-color: var(--color-bg-card); padding: 24rpx; margin-bottom: 2rpx; }
.item-select { width: 48rpx; height: 48rpx; display: flex; align-items: center; justify-content: center; }
.check-icon { width: 40rpx; height: 40rpx; }
.item-image { width: 160rpx; height: 160rpx; border-radius: var(--radius-small); margin: 0 16rpx; }
.item-info { flex: 1; }
.item-name { font-size: 28rpx; display: block; margin-bottom: 8rpx; }
.item-price { color: var(--color-primary); font-size: 32rpx; font-weight: bold; margin-bottom: 8rpx; }
.item-quantity { display: flex; align-items: center; gap: 16rpx; }
.item-quantity button { width: 48rpx; height: 48rpx; line-height: 48rpx; }
.item-remove { color: var(--color-text-tertiary); font-size: 24rpx; }
.empty { text-align: center; padding: 200rpx 0; color: var(--color-text-tertiary); }
.empty button { margin-top: 32rpx; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; display: flex; align-items: center; padding: 24rpx; background-color: var(--color-bg-card); border-top: 1rpx solid var(--color-border-light); }
.select-all { display: flex; align-items: center; gap: 8rpx; width: 160rpx; }
.total-info { flex: 1; text-align: right; margin-right: 24rpx; }
.total-price { color: var(--color-primary); font-size: 36rpx; font-weight: bold; }
.btn-checkout { background-color: var(--color-primary); color: #fff; border-radius: var(--radius-large); padding: 0 48rpx; height: 80rpx; line-height: 80rpx; }