.container { padding-bottom: 120rpx; }
.cart-item { display: flex; align-items: center; padding: 24rpx; background: #fff; margin-bottom: 2rpx; }
.item-image { width: 160rpx; height: 160rpx; border-radius: 12rpx; margin: 0 20rpx; background: #f5f5f5; }
.item-info { flex: 1; }
.item-name { font-size: 28rpx; color: #333; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 12rpx; }
.item-bottom { display: flex; align-items: center; justify-content: space-between; }
.item-price { color: #ff6347; font-size: 30rpx; font-weight: bold; }
.count-control { display: flex; align-items: center; gap: 16rpx; }
.count-control text { width: 40rpx; height: 40rpx; border: 1px solid #ddd; display: flex; align-items: center; justify-content: center; font-size: 24rpx; }
.count { min-width: 40rpx; text-align: center; }
.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 200rpx 0; color: #999; font-size: 28rpx; }
.btn-go-shopping { margin-top: 32rpx; padding: 20rpx 48rpx; background: #ff6347; color: #fff; border-radius: 40rpx; font-size: 28rpx; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; height: 100rpx; background: #fff; border-top: 1px solid #eee; display: flex; align-items: center; padding: 0 24rpx; }
.select-all { display: flex; align-items: center; gap: 8rpx; font-size: 26rpx; color: #666; }
.total-info { flex: 1; display: flex; align-items: baseline; justify-content: flex-end; gap: 8rpx; margin-right: 24rpx; }
.total-price { color: #ff6347; font-size: 36rpx; font-weight: bold; }
.btn-checkout { background: #ff6347; color: #fff; padding: 0 40rpx; height: 72rpx; line-height: 72rpx; border-radius: 36rpx; font-size: 28rpx; }
