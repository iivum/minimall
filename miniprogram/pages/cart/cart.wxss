/* pages/cart/cart.wxss */
.cart-list { padding-bottom: 120rpx; }
.cart-item { display: flex; align-items: center; background-color: #fff; padding: 24rpx; margin-bottom: 2rpx; }
.item-select { width: 48rpx; height: 48rpx; display: flex; align-items: center; justify-content: center; }
.check-icon { width: 40rpx; height: 40rpx; }
.item-image { width: 160rpx; height: 160rpx; border-radius: 8rpx; margin: 0 16rpx; }
.item-info { flex: 1; }
.item-name { font-size: 28rpx; display: block; margin-bottom: 8rpx; }
.item-price { color: #FF6B6B; font-size: 32rpx; font-weight: bold; margin-bottom: 8rpx; }
.item-quantity { display: flex; align-items: center; gap: 16rpx; }
.item-quantity button { width: 48rpx; height: 48rpx; line-height: 48rpx; }
.item-remove { color: #999; font-size: 24rpx; }
.empty { text-align: center; padding: 200rpx 0; color: #999; }
.empty button { margin-top: 32rpx; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; display: flex; align-items: center; padding: 24rpx; background-color: #fff; border-top: 1rpx solid #eee; }
.select-all { display: flex; align-items: center; gap: 8rpx; width: 160rpx; }
.total-info { flex: 1; text-align: right; margin-right: 24rpx; }
.total-price { color: #FF6B6B; font-size: 36rpx; font-weight: bold; }
.btn-checkout { background-color: #FF6B6B; color: #fff; border-radius: 48rpx; padding: 0 48rpx; height: 80rpx; line-height: 80rpx; }