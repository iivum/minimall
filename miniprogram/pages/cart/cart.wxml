<!-- pages/cart/cart.wxml -->
<view class="container">
  <!-- 购物车列表 -->
  <view class="cart-list" wx:if="{{cartItems.length > 0}}">
    <view class="cart-item" wx:for="{{cartItems}}" wx:key="id">
      <view class="item-select" bindtap="toggleSelect" data-index="{{index}}" hover-class="item-press">
        <image class="check-icon" src="{{item.selected !== false ? '/assets/images/checked.png' : '/assets/images/unchecked.png'}}" />
      </view>
      <image class="item-image" mode="aspectFill" src="{{item.imageUrl}}" />
      <view class="item-info">
        <text class="item-name">{{item.name}}</text>
        <view class="item-price">¥{{item.price}}</view>
        <view class="item-quantity">
          <view class="quantity-btn minus {{item.quantity <= 1 ? 'disabled' : ''}}" data-index="{{index}}" data-type="minus" bindtap="onQuantityChange">-</view>
          <text class="quantity-num">{{item.quantity}}</text>
          <view class="quantity-btn plus" data-index="{{index}}" data-type="plus" bindtap="onQuantityChange">+</view>
        </view>
      </view>
      <view class="item-remove" bindtap="removeItem" data-index="{{index}}" hover-class="remove-active">删除</view>
    </view>
  </view>
  <!-- 空状态 -->
  <view class="empty" wx:if="{{cartItems.length === 0}}">
    <image class="empty-icon" src="/assets/images/empty-cart.png" mode="aspectFit" />
    <text class="empty-text">购物车是空的</text>
    <text class="empty-hint">快去挑选心仪的商品吧</text>
    <button class="btn-primary" bindtap="goShopping">去逛逛</button>
  </view>
  <!-- 底部结算栏 -->
  <view class="bottom-bar" wx:if="{{cartItems.length > 0}}">
    <view class="select-all" bindtap="toggleAllSelect" hover-class="item-press">
      <image class="check-icon" src="{{allSelected ? '/assets/images/checked.png' : '/assets/images/unchecked.png'}}" />
      <text>全选</text>
    </view>
    <view class="total-info">
      <text class="total-label">合计:</text>
      <text class="total-price">¥{{totalPrice}}</text>
    </view>
    <view class="btn-checkout {{selectedCount === 0 ? 'disabled' : ''}}" bindtap="checkout">结算({{selectedCount}})</view>
  </view>
</view>