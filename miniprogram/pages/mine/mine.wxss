.container { background: #f5f5f5; min-height: 100vh; }
.user-section { background: linear-gradient(135deg, #ff6347 0%, #ff8c5a 100%); padding: 60rpx 40rpx 80rpx; }
.user-info { display: flex; align-items: center; }
.avatar { width: 120rpx; height: 120rpx; border-radius: 60rpx; border: 4rpx solid rgba(255,255,255,0.5); }
.user-detail { margin-left: 24rpx; }
.nickname { display: block; font-size: 36rpx; color: #fff; font-weight: bold; margin-bottom: 8rpx; }
.login-tip { font-size: 24rpx; color: rgba(255,255,255,0.8); }
.member-grade { display: flex; align-items: center; gap: 16rpx; margin-top: 24rpx; background: rgba(255,255,255,0.2); padding: 12rpx 24rpx; border-radius: 32rpx; width: fit-content; }
.grade-name { font-size: 28rpx; color: #fff; font-weight: bold; }
.grade-benefit { font-size: 24rpx; color: rgba(255,255,255,0.9); }
.order-section { background: #fff; margin: -40rpx 24rpx 20rpx; border-radius: 16rpx; padding: 24rpx; }
.order-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.section-title { font-size: 30rpx; font-weight: bold; color: #333; }
.look-all { font-size: 26rpx; color: #999; }
.order-tabs { display: flex; justify-content: space-around; }
.order-tab-item { display: flex; flex-direction: column; align-items: center; gap: 12rpx; }
.tab-icon { font-size: 48rpx; }
.tab-name { font-size: 24rpx; color: #666; }
.menu-section { background: #fff; margin: 0 24rpx 20rpx; border-radius: 16rpx; padding: 0 24rpx; }
.menu-item { display: flex; align-items: center; padding: 32rpx 0; border-bottom: 1px solid #f5f5f5; }
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 40rpx; margin-right: 20rpx; }
.menu-name { flex: 1; font-size: 28rpx; color: #333; }
.menu-arrow { font-size: 28rpx; color: #ccc; }
