/** app.wxss **/
@import "./tokens.wxss";

page {
  background-color: var(--color-bg-page);
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.container {
  padding: 24rpx;
}

.price {
  color: var(--color-primary);
  font-weight: bold;
}

.original-price {
  color: var(--color-text-tertiary);
  text-decoration: line-through;
  font-size: 24rpx;
}

.btn-primary {
  background-color: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-small);
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  text-align: center;
}

.btn-secondary {
  background-color: var(--color-bg-card);
  color: var(--color-text-primary);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-small);
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  text-align: center;
}

.btn-disabled {
  background-color: var(--color-bg-disabled);
  color: #fff;
}

.card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-medium);
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.text-primary {
  color: var(--color-primary);
}

.text-secondary {
  color: var(--color-text-tertiary);
}

.text-small {
  font-size: 24rpx;
}

.text-bold {
  font-weight: bold;
}