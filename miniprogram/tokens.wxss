/**
 * Design Tokens - Design Token System
 * 使用 CSS 变量定义设计令牌，支持亮色/暗色主题切换
 *
 * 使用方式：
 * 1. 在 app.wxss 中导入：@import "./tokens.wxss";
 * 2. 在组件中直接使用 var(--color-primary)
 */

/* ============================================
   品牌色 (Brand Colors)
   ============================================ */
page {
  /* 品牌主色 - 珊瑚红 */
  --color-primary: #FF6B6B;
  --color-primary-rgb: 255, 107, 107;

  /* 品牌渐变色终点 */
  --color-secondary: #FF8E53;

  /* 功能色 */
  --color-success: #07C160;
  --color-success-rgb: 7, 193, 96;

  --color-warning: #FF9800;
  --color-warning-rgb: 255, 152, 0;

  --color-info: #2196F3;
  --color-info-rgb: 33, 150, 243;

  --color-error: #FF6B6B;
  --color-error-rgb: 255, 107, 107;

  /* ============================================
     中性色 (Neutral Colors)
     ============================================ */
  /* 文本色 */
  --color-text-primary: #333333;
  --color-text-secondary: #666666;
  --color-text-tertiary: #999999;
  --color-text-disabled: #CCCCCC;

  /* 背景色 */
  --color-bg-page: #F5F5F5;
  --color-bg-card: #FFFFFF;
  --color-bg-disabled: #CCCCCC;
  --color-bg-input: #F5F5F5;

  /* 边框色 */
  --color-border: #DDDDDD;
  --color-border-light: #EEEEEE;
  --color-border-lighter: #F0F0F0;

  /* 状态文字色 */
  --color-success-text: #4CAF50;
  --color-warning-text: #FF9800;
  --color-info-text: #2196F3;

  /* ============================================
     暗色主题 (Dark Mode)
     ============================================ */
  --dark-color-text-primary: #E5E5E5;
  --dark-color-text-secondary: #B0B0B0;
  --dark-color-text-tertiary: #808080;
  --dark-color-text-disabled: #4D4D4D;

  --dark-color-bg-page: #1A1A1A;
  --dark-color-bg-card: #2D2D2D;
  --dark-color-bg-disabled: #4D4D4D;
  --dark-color-bg-input: #262626;

  --dark-color-border: #404040;
  --dark-color-border-light: #3A3A3A;
  --dark-color-border-lighter: #262626;

  /* 暗色主题下保持品牌色不变 */
  --dark-color-primary: #FF6B6B;
  --dark-color-success: #07C160;
  --dark-color-warning: #FF9800;
  --dark-color-info: #2196F3;
  --dark-color-error: #FF6B6B;

  /* ============================================
     圆角 (Border Radius)
     ============================================ */
  --radius-small: 8rpx;
  --radius-medium: 12rpx;
  --radius-large: 48rpx;
  --radius-circle: 50%;

  /* ============================================
     阴影 (Shadow)
     ============================================ */
  --shadow-card: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  --shadow-popup: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

/* ============================================
   暗色主题类 (Dark Mode Class)
   ============================================ */
.dark-mode,
[theme="dark"] {
  --color-text-primary: var(--dark-color-text-primary);
  --color-text-secondary: var(--dark-color-text-secondary);
  --color-text-tertiary: var(--dark-color-text-tertiary);
  --color-text-disabled: var(--dark-color-text-disabled);

  --color-bg-page: var(--dark-color-bg-page);
  --color-bg-card: var(--dark-color-bg-card);
  --color-bg-disabled: var(--dark-color-bg-disabled);
  --color-bg-input: var(--dark-color-bg-input);

  --color-border: var(--dark-color-border);
  --color-border-light: var(--dark-color-border-light);
  --color-border-lighter: var(--dark-color-border-lighter);
}
